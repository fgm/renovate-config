# Renovate secrets + settings for the self-hosted runner.
# Copy to renovate.env next to renovate-run.sh, fill in, and `chmod 600`.
# NEVER commit the filled-in renovate.env (see ../.gitignore).

# GitHub classic PAT. Scopes: repo + workflow.
#   - repo:     create renovate/* branches and PRs (bo_htmx is private -> full repo, not public_repo).
#   - workflow: REQUIRED because the shared preset pins GitHub Action digests, so Renovate
#               edits .github/workflows/*.yml; GitHub rejects workflow-file pushes without it.
# Provenance: fgm laptop ~/.netrc, machine github.com.
GITHUB_TOKEN=

# GitLab PAT (glpat-...). Scope: api.
# Provenance: fgm laptop ~/.netrc, machine gitlab.com (fingerprint sha256[:12]=9eb558a62129).
GITLAB_TOKEN=

# Pin Renovate to a version compatible with the host's Node.
# cof runs Node 22 (shared with the Gogs 0.15-dev vite frontend -- do NOT upgrade it on prod),
# so pin to major 42: it supports node ^22.13.0 || ^24.11.0; renovate 43+ requires Node 24.
# Once the host is on Node 24 (e.g. after the Forgejo migration, WOF-47, removes the Node-on-server
# requirement), this pin can be dropped to track latest.
RENOVATE_VERSION=42

# Keep Renovate's repo clones and the npm/npx cache OFF the host's small root fs.
# On cof, / is a full 20G volume and /var/www (xfs, 30G) is the data volume that already
# holds Docker + the Gogs repos; point both caches there. Adjust paths per host.
RENOVATE_BASE_DIR=/var/www/renovate/base
npm_config_cache=/var/www/renovate/npmcache

